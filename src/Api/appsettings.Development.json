{
  "DefraIdentityApiKey": "test",
  "AWS": {
    "UseLocalStack": true,
    "ServiceURL": "http://localhost:4566",
    "Region": "eu-west-2",
    "AccessKey": "test",
    "SecretKey": "test"
  },
  "QueueOptions": {
    "IntakeQueueOptions": {
      "Url": "http://localhost:4566/000000000000/identity_service_helper_intake"
    }
  },
  "KrdsApi": {
    "Url": "https://ls-keeper-data-api.api.ext-test.cdp.defra.gov.uk/api/",
    "ClientId": "changeme",
    "ClientSecret": "changeme",
    "TokenUrl": "https://ls-keeper-data-api-8ec5c.auth.eu-west-2.amazoncognito.com/oauth2/token"
  },
  "PolledServices": {
    "AzureB2CSyncService": {
      "CronSchedule": "*/30 * * * * ?"
    }
  },
  "ConnectionStrings": {
    "PostgresConnection": "User ID=identity_service_helper_ddl;Password=postgres;Host=localhost;Database=identity_service_helper;",
    "ReadOnlyPostgresConnection": "User ID=identity_service_helper_ddl;Password=postgres;Host=localhost;Database=identity_service_helper;"
  },
  "KrdsApiService": {
    "ApiUrl": "http://localhost:8080/api"
  },
  "DetailedErrors": true,
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:o} [{Level:u4}] ({Application}/{MachineName}/{ThreadId}/{SourceContext}.{Method}) {Message}{NewLine}{Exception}"
        }
      }
    ]
  }
