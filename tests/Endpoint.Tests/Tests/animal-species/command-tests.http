### Reset the local database
< ../../Asserts/data-scaffold.js
GET {{host}}/health

### GET request to animal-species to the species list
GET {{host}}/animal-species
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_200_OK_and_get_paged_ids.js

### show the animal-species
POST {{host}}/animal-species/DR:toggle
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

{
  "is_active": true
}

> ../../Asserts/Should_be_204_no_content.js

### show the animal-species again and expect a conflict
POST {{host}}/animal-species/DR:toggle
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_204_no_content.js

