### Reset the local database
< ../../Asserts/data-scaffold.js
GET {{host}}/health

### GET request to applications to get top user 
GET {{host}}/users
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_200_OK_and_get_top_id.js

### Create new Application should fail validation error missing name
POST {{host}}/applications
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

{
  "name": "",
  "client_id": "{{$random.internet.uuid}}",
  "tenant_name": "TestTenant",
  "description": "Test Description",
  "scopes": ["scope1", "scope2"],
  "secret": "{{$random.alphabetic(16)}}",
  "redirect_uris" :["https://localhost1.com"]
 
}

> ../../Asserts/Should_be_422_error_response.js

### Create new Application
POST {{host}}/applications
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

{
  "name": "App_{{$random.alphanumeric(8)}}",
  "id": "{{$random.internet.uuid}}",
  "tenant_name": "Tenant_{{$random.alphanumeric(5)}}",
  "description": "Description_{{$random.alphanumeric(20)}}",
   "scopes": ["scope1", "scope2"],
  "secret": "{{$random.alphabetic(16)}}",
  "redirect_uris" :["https://localhost1.com", "https://localhost2.com"]
}

> ../../Asserts/Should_be_201_created.js

### PUT request to update an existing application
PUT {{host}}/applications/{{id}}
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

{
  "name": "UpdatedApp_{{$random.alphanumeric(8)}}",
  "tenant_name": "UpdatedTenant",
  "description": "Updated Description",
  "scopes": ["scope1", "scope2"],
  "secret": "{{$random.alphabetic(16)}}",
  "redirect_uris" :["https://localhost1.com", "https://localhost2.com", "https://localhost3.com"]
}

> ../../Asserts/Should_be_200_OK.js


### DELETE the application 
DELETE {{host}}/applications/{{id}}
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}


> ../../Asserts/Should_be_204_no_content.js
