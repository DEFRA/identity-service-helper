### Reset the local database
< ../../Asserts/data-scaffold.js
GET {{host}}/health

### GET request to users to get top admin
GET {{host}}/users
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_200_OK_and_get_top_id.js

### GET request to get top none expired cph on first page
GET {{host}}/cphs?pageNumber=1&pageSize=20
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_200_OK_and_get_paged_top_id.js

### EXPIRE the cph
POST {{host}}/cphs/{{id}}:expire
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_204_no_content.js

### EXPIRE the cph again and expect a conflict
POST {{host}}/cphs/{{id}}:expire
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_409_conflict.js

### DELETE the cph
DELETE {{host}}/cphs/{{id}}
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_204_no_content.js

### DELETE the cph again and expect not found
DELETE {{host}}/cphs/{{id}}
Content-Type: application/json
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
x-operator-id: {{operator-id}}

> ../../Asserts/Should_be_404.js

