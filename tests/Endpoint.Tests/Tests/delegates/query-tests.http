### Reset the local database
< ../../Asserts/data-scaffold.js
GET {{host}}/health

### GET request to delegations (Defaults to all delegations)
GET {{host}}/delegations
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}

> ../../Asserts/Should_be_200_OK_and_get_top_id.js

### Get application By Id
GET {{host}}/delegations/{{id}}
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}

> ../../Asserts/Should_be_200_OK.js

### Should return 404 application does not exist
GET {{host}}/delegations/{{$random.internet.uuid}}
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}

> ../../Asserts/Should_be_404.js
