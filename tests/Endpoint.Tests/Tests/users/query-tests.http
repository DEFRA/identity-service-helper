### Reset the local database
< ../../Asserts/data-scaffold.js
GET {{host}}/health

### GET request to users (Defaults to active users)
GET {{host}}/users
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}
 
> ../../Asserts/Should_be_200_OK_and_get_top_id.js
### GET new  users 
GET {{host}}/users?status=new
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}

> ../../Asserts/Should_be_200_OK.js
### GET All deleted users 
GET {{host}}/users?status=deleted
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}

> ../../Asserts/Should_be_200_OK.js

### GET ALL suspended users 
GET {{host}}/users?status=deleted
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}

> ../../Asserts/Should_be_200_OK.js

### Get user By Id
GET {{host}}/users/{{id}}
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}

> ../../Asserts/Should_be_200_OK.js

### Should return 404 user does not exist
GET {{host}}/users/{{$random.internet.uuid}}
x-correlation-id: {{correlation-id}}
x-api-key: {{api-key}}

> ../../Asserts/Should_be_404.js

### GET Invalid API Key Provided
GET {{host}}/users
